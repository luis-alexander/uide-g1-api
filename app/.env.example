# ─── Copiar este archivo como .env y completar valores ───────────────────────
# cp .env.example .env

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Tu correo de Gmail
GMAIL_USER=tu_correo@gmail.com

# Contraseña de aplicación Gmail (NO tu contraseña normal)
# Cómo obtenerla: https://myaccount.google.com/apppasswords
# Pasos: Google Account → Seguridad → Verificación en 2 pasos → Contraseñas de app
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── JWT ───────────────────────────────────────────────────────────────────────
# Clave secreta para firmar tokens (cambiar en producción)
JWT_SECRET=super-secret-key-maestria-2025-CAMBIAR

# Horas de expiración del token
JWT_EXPIRE_HOURS=24
